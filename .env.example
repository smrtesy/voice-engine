# ─── Server Configuration ───────────────────────────────────────────────────
PORT=8000
ENVIRONMENT=production
LOG_LEVEL=INFO
SERVICE_ROLE=api

# ─── Authentication ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
VOICE_ENGINE_API_KEY=
WEBHOOK_SIGNING_SECRET=

# ─── Resemble AI ────────────────────────────────────────────────────────────
RESEMBLE_API_KEY=
RESEMBLE_API_BASE_URL=https://app.resemble.ai/api/v2
# Project that holds the cloned voices. Synthesis is project-scoped
# (POST /projects/{uuid}/clips) — the bare /clips endpoint 404s. REQUIRED.
RESEMBLE_PROJECT_UUID=
RESEMBLE_DEFAULT_SAMPLE_RATE=48000
RESEMBLE_DEFAULT_PRECISION=PCM_24
RESEMBLE_DEFAULT_USE_HD=true
# Options: empty | chatterbox | chatterbox-turbo | resemble-ultra
# resemble-ultra is the tested Hebrew recipe (emotion via tags in the body).
RESEMBLE_DEFAULT_MODEL=resemble-ultra

# ─── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.3

# ─── Supabase ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOURPROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=smrtvoice-audio

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ─── Google APIs ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Smrtesy Integration ────────────────────────────────────────────────────
SMRTESY_API_URL=https://smrtesy.up.railway.app
SMRTESY_WEBHOOK_PATH=/api/voice/webhook

# ─── Adapter Selection ──────────────────────────────────────────────────────
DEFAULT_TTS_ADAPTER=resemble

# ─── Job Settings ───────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2
JOB_TIMEOUT_SECONDS=3600
MAX_CONCURRENT_LINES=5
WEBHOOK_RETRY_MAX=5

# ─── Cost Control ───────────────────────────────────────────────────────────
DEFAULT_MONTHLY_BUDGET_USD=100
COST_CHECK_BEFORE_JOB=true
